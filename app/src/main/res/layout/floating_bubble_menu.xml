<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="4dp">

    <!-- Main bubble button (always visible) -->
    <ImageView
        android:id="@+id/btn_bubble"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_floating_button"
        android:src="@drawable/ic_capture"
        android:padding="8dp"
        android:contentDescription="Capture menu" />

    <!-- Expanded menu buttons: 2 rows x 4 columns grid -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <!-- Row 1: Play, Stop, Camera, Pencil -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_continuous_start"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_media_play"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Start continuous capture" />

            <ImageView
                android:id="@+id/btn_continuous_stop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_media_pause"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Stop continuous capture" />

            <ImageView
                android:id="@+id/btn_single_capture"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_floating_button"
                android:src="@drawable/ic_capture"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Single capture" />

            <ImageView
                android:id="@+id/btn_region_edit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_menu_edit"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Edit capture regions" />

        </LinearLayout>

        <!-- Row 2: AutoRead, Profile, OverlayMode, ScreenSwitch -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_auto_read_toggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_btn_speak_now"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Toggle auto-read" />

            <ImageView
                android:id="@+id/btn_profile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_menu_manage"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Profiles" />

            <ImageView
                android:id="@+id/btn_overlay_mode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_menu_slideshow"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Toggle overlay mode" />

            <ImageView
                android:id="@+id/btn_screen_switch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_floating_button"
                android:src="@android:drawable/ic_menu_rotate"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="Move to other screen" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
